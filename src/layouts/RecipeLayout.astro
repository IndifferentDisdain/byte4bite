---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Nutrition {
  calories: number;
  protein: number;
  carbs: number;
  fat: number;
  fiber?: number;
  sodium?: number;
}

interface Props {
  title: string;
  description: string;
  heroImage?: ImageMetadata;
  category?: string;
  prepTime?: string;
  cookTime?: string;
  servings?: string;
  tags?: string[];
  pubDate: Date;
  nutrition?: Nutrition;
}

const { title, description, heroImage, category, prepTime, cookTime, servings, tags, pubDate, nutrition } = Astro.props;

const formatted = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <!-- Recipe header -->
  <div class="bg-b4b-green text-b4b-cream pt-20 pb-16 px-6">
    <div class="max-w-3xl mx-auto text-center">
      {category && (
        <p class="font-ui text-xs tracking-brand uppercase text-b4b-cream/60 mb-4">{category}</p>
      )}
      <h1 class="font-display text-5xl md:text-6xl font-semibold leading-tight mb-6">
        {title}
      </h1>
      <p class="font-body italic text-b4b-cream/80 text-lg md:text-xl max-w-xl mx-auto mb-8">
        {description}
      </p>

      <!-- Meta chips -->
      {(prepTime || cookTime || servings) && (
        <div class="flex flex-wrap items-center justify-center gap-3">
          {prepTime && (
            <div class="border border-b4b-cream/30 px-4 py-2 text-center">
              <div class="font-ui text-xs tracking-widest uppercase text-b4b-cream/50 mb-0.5">Prep</div>
              <div class="font-display text-base text-b4b-cream">{prepTime}</div>
            </div>
          )}
          {cookTime && (
            <div class="border border-b4b-cream/30 px-4 py-2 text-center">
              <div class="font-ui text-xs tracking-widest uppercase text-b4b-cream/50 mb-0.5">Cook</div>
              <div class="font-display text-base text-b4b-cream">{cookTime}</div>
            </div>
          )}
          {servings && (
            <div class="border border-b4b-cream/30 px-4 py-2 text-center">
              <div class="font-ui text-xs tracking-widest uppercase text-b4b-cream/50 mb-0.5">Serves</div>
              <div class="font-display text-base text-b4b-cream">{servings}</div>
            </div>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Hero image -->
  {heroImage && (
    <div class="w-full max-h-[480px] overflow-hidden">
      <Image
        src={heroImage}
        alt={title}
        widths={[800, 1200, 1600]}
        sizes="100vw"
        class="w-full h-full object-cover"
      />
    </div>
  )}

  <!-- Recipe body -->
  <article class="max-w-2xl mx-auto px-6 py-14">
    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        {tags.map(tag => (
          <span class="tag-pill">{tag}</span>
        ))}
      </div>
    )}

    <!-- Markdown content -->
    <div class="
      prose prose-stone max-w-none
      prose-headings:font-display prose-headings:font-semibold prose-headings:text-b4b-charcoal
      prose-h2:text-3xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-2xl
      prose-p:font-body prose-p:text-b4b-charcoal prose-p:leading-relaxed
      prose-li:font-body prose-li:text-b4b-charcoal
      prose-strong:font-semibold prose-strong:text-b4b-charcoal
      prose-a:text-b4b-green prose-a:underline-offset-2
      prose-hr:border-b4b-tan
      prose-ol:list-decimal prose-ul:list-disc
    ">
      <slot />
    </div>

    <!-- Nutrition -->
    {nutrition && (
      <div class="mt-14 border border-b4b-tan p-6">
        <h2 class="font-ui text-xs tracking-brand uppercase text-b4b-charcoal/50 mb-4 text-center">
          Nutrition <span class="normal-case">· per serving · estimated</span>
        </h2>
        <div class="flex flex-wrap justify-center gap-6">
          <div class="text-center">
            <div class="font-display text-2xl text-b4b-charcoal">{nutrition.calories}</div>
            <div class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/50 mt-0.5">Calories</div>
          </div>
          <div class="text-center">
            <div class="font-display text-2xl text-b4b-charcoal">{nutrition.protein}g</div>
            <div class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/50 mt-0.5">Protein</div>
          </div>
          <div class="text-center">
            <div class="font-display text-2xl text-b4b-charcoal">{nutrition.carbs}g</div>
            <div class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/50 mt-0.5">Carbs</div>
          </div>
          <div class="text-center">
            <div class="font-display text-2xl text-b4b-charcoal">{nutrition.fat}g</div>
            <div class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/50 mt-0.5">Fat</div>
          </div>
          {nutrition.fiber && (
            <div class="text-center">
              <div class="font-display text-2xl text-b4b-charcoal">{nutrition.fiber}g</div>
              <div class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/50 mt-0.5">Fiber</div>
            </div>
          )}
          {nutrition.sodium && (
            <div class="text-center">
              <div class="font-display text-2xl text-b4b-charcoal">{nutrition.sodium}mg</div>
              <div class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/50 mt-0.5">Sodium</div>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Footer divider -->
    <div class="star-divider mt-14">
      <span class="text-b4b-green text-sm">✦ ✦ ✦</span>
    </div>

    <p class="text-center font-ui text-xs tracking-widest uppercase text-b4b-charcoal/40 mt-6">
      Published {formatted}
    </p>

    <div class="mt-10 text-center">
      <a href="/recipes" class="font-ui text-xs tracking-brand uppercase text-b4b-green
        border-b border-b4b-green pb-0.5 hover:text-b4b-green-dk transition-colors">
        ← All Recipes
      </a>
    </div>
  </article>
</BaseLayout>
