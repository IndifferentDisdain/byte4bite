---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  slug: string;
  heroImage?: ImageMetadata;
  category?: string;
  prepTime?: string;
  cookTime?: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, slug, heroImage, category, prepTime, cookTime, tags, featured } = Astro.props;
---

<a
  href={`/recipes/${slug}`}
  class="group block bg-white border border-b4b-tan hover:border-b4b-green transition-colors duration-300"
>
  <!-- Top accent bar -->
  <div class="h-0.5 bg-b4b-green w-0 group-hover:w-full transition-all duration-300"></div>

  <!-- Hero image -->
  {heroImage && (
    <div class="overflow-hidden aspect-[3/2]">
      <Image
        src={heroImage}
        alt={title}
        widths={[400, 800]}
        sizes="(max-width: 768px) 100vw, 400px"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
  )}

  <div class="p-7">
    <!-- Category & featured -->
    <div class="flex items-center gap-3 mb-4">
      {category && (
        <span class="eyebrow">{category}</span>
      )}
      {featured && (
        <span class="font-ui text-xs tracking-wide text-b4b-cream bg-b4b-green px-2 py-0.5">
          Featured
        </span>
      )}
    </div>

    <!-- Title -->
    <h3 class="font-display text-2xl md:text-3xl font-semibold text-b4b-charcoal leading-snug mb-3
               group-hover:text-b4b-green transition-colors duration-200">
      {title}
    </h3>

    <!-- Description -->
    <p class="font-body text-sm text-b4b-charcoal/60 leading-relaxed mb-5 line-clamp-2">
      {description}
    </p>

    <!-- Times -->
    {(prepTime || cookTime) && (
      <div class="flex items-center gap-4 pt-4 border-t border-b4b-tan">
        {prepTime && (
          <div>
            <span class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/40">Prep </span>
            <span class="font-ui text-xs text-b4b-charcoal/60">{prepTime}</span>
          </div>
        )}
        {cookTime && (
          <div>
            <span class="font-ui text-xs tracking-widest uppercase text-b4b-charcoal/40">Cook </span>
            <span class="font-ui text-xs text-b4b-charcoal/60">{cookTime}</span>
          </div>
        )}
      </div>
    )}
  </div>
</a>
