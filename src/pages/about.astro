---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="What Byte4Bite is about — real recipes, real techniques, and an honest record of what works."
>
  <!-- Header -->
  <div class="bg-b4b-green text-b4b-cream pt-20 pb-14 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <p class="font-ui text-xs tracking-brand uppercase text-b4b-cream/50 mb-4">The Story</p>
      <h1 class="font-display text-5xl md:text-6xl font-semibold">About</h1>
    </div>
  </div>

  <!-- Content -->
  <section class="max-w-2xl mx-auto px-6 py-20">
    <div class="star-divider mb-12">
      <span class="text-b4b-green text-sm">✦ ✦ ✦</span>
    </div>

    <div class="space-y-6 font-body text-b4b-charcoal/80 leading-relaxed text-base">
      <p>
        Byte4Bite is a record of food worth making. Started in 2020, it's a home for recipes that
        have been tested, refined, and earned their place — not curated for aesthetics, not padded
        for SEO.
      </p>
      <p>
        The focus is on technique as much as recipe. Understanding <em>why</em> something works
        matters more than following steps blindly. Most of what's here leans toward smoke, fire,
        cast iron, and patience — but weeknight practicality gets its fair share too.
      </p>
      <p>
        No fluff. No life stories before the ingredients. Just real cooking.
      </p>
    </div>

    <div class="star-divider my-12">
      <span class="text-b4b-green text-sm">✦ ✦ ✦</span>
    </div>

    <div class="text-center">
      <a
        href="/recipes"
        class="font-ui text-xs tracking-brand uppercase text-b4b-green
               border border-b4b-green px-8 py-3 hover:bg-b4b-green hover:text-b4b-cream
               transition-colors duration-200 inline-block"
      >
        Browse Recipes
      </a>
    </div>
  </section>
</BaseLayout>
